<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Style for all Buttons -->
    <style name="CalculatorButtonBase" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">24dp</item>
        <item name="backgroundTint">#A5A5A5</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Number Button Style -->
    <style name="ButtonStyle.Number" parent="CalculatorButtonBase">
    </style>

    <!-- Operator Button Style (+, -, *, /) -->
    <style name="ButtonStyle.Operator" parent="CalculatorButtonBase">
        <item name="android:textSize">28sp</item>
    </style>

    <!-- Action Button Style (C, CE, Backspace) -->
    <style name="ButtonStyle.Action" parent="CalculatorButtonBase">
        <item name="android:textSize">20sp</item>
    </style>

    <!-- Equal Button Style -->
    <style name="ButtonStyle.Equal" parent="CalculatorButtonBase">
    </style>

</resources>
